{
  "name": "todo-web-app",
  "version": "1.0.0",
  "description": "A simple todo-list application which helps a user to manage their tasks.",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "test": "cross-env NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage ",
    "start": "node backend/server.js",
    "server": "nodemon backend/server.js",
    "client": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "cd frontend && npm install && npm run build && cd .."
  },
  "repository": {
    "type": "git",
    "url": "git+"
  },
  "keywords": [
    "todo",
    "react",
    "mongo",
    "node",
    "express",
    "tailwind"
  ],
  "author": "Ozair Hassan <ozair.hassan123@gmail.com>",
  "license": "MIT",
  "homepage": "",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-handler": "^1.2.0",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.3.0",
    "mongoose": "^8.0.4"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.4"
  }
}
